# Copy this file to .env and fill in the values below.
# Never commit .env — it is already listed in .gitignore.

# --- Backboard (https://app.backboard.io -> Settings -> API Keys) ---
BACKBOARD_API_KEY=
# Created by `python scripts/setup_backboard_assistant.py`
BACKBOARD_ASSISTANT_ID=
# Optional. e.g. openai — leave blank to use Backboard's default vision-capable model
BACKBOARD_PROVIDER=
# Optional. e.g. gpt-4o — leave blank to use Backboard's default model
BACKBOARD_MODEL=

# --- ElevenLabs (https://elevenlabs.io -> Profile -> API Keys) ---
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
# Required only if TTS_ENABLED=true
ELEVENLABS_VOICE_ID=

# --- Audio / capture ---
AUDIO_BUFFER_SECONDS=10
CAPTURE_SECONDS=10
# Leave blank to use the system default input device. If recordings come back
# silent/empty despite correct permissions, you likely have multiple input
# devices and the wrong one is default — list them with:
#   python -c "import sounddevice as sd; print(sd.query_devices())"
# and set this to the index of your real microphone (machine-specific, do not
# assume the same index works on a teammate's machine or on the Pi).
MIC_DEVICE_INDEX=

# --- Camera: laptop | sample | pi (pi requires Raspberry Pi OS + picamera2, see requirements-pi.txt) ---
CAMERA_MODE=laptop
CAMERA_INDEX=0

# --- Trigger: software (Tkinter button) | gpio (Raspberry Pi physical button, Task 13) ---
TRIGGER_MODE=software
# BCM pin number for the physical button (gpio mode only); button wired between this pin and GND
GPIO_BUTTON_PIN=17

# --- Feature flags ---
TTS_ENABLED=false
DEMO_MODE=false

# --- Sample assets used by demo mode (see scripts/generate_sample_assets.py) ---
SAMPLE_AUDIO_PATH=samples/audio/sample.wav
SAMPLE_IMAGE_PATH=samples/images/sample.jpg

# --- Advanced / rarely changed ---
MIC_SAMPLE_RATE=16000
BACKBOARD_BASE_URL=https://app.backboard.io/api
REQUEST_TIMEOUT_SECONDS=30
